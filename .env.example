# .env.example — copy to .env and adjust values

# PostgreSQL
POSTGRES_USER=kronos
POSTGRES_PASSWORD=kronos
POSTGRES_DB=kronos
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend / JWT
JWT_SECRET_KEY=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
